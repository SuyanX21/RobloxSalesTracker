{
  "manifest_version": 3,
  "name": "Roblox Sales Tracker",
  "version": "3.6",
  "description": "Standalone Roblox sales intelligence dashboard and real-time sales tracker.",
  "permissions": ["storage"],
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_icon": "images/icon48.png",
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://www.roblox.com/*",
    "https://economy.roblox.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.roblox.com/communities/configure*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "donate.html",
        "help.html",
        "settings.html",
        "settings.js",
        "analytics.html",
        "analytics.css",
        "analytics.js",
        "background.js",
        "images/*"
      ],
      "matches": ["https://www.roblox.com/*"]
    }
  ]
}
